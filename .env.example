# Copy to .env and fill in real values. Do NOT commit .env.
#
# ── Multi-workspace (public OAuth distribution) mode ────────────────────────
# From https://api.slack.com/apps → your app → Basic Information → App Credentials
SLACK_CLIENT_ID=your-client-id
SLACK_CLIENT_SECRET=your-client-secret
SLACK_SIGNING_SECRET=your-signing-secret
# Postgres for per-workspace tokens + campaigns + audit chain
DATABASE_URL=postgres://user:pass@host:5432/dbname
# Any strong random string — encrypts workspace bot tokens at rest
TOKEN_ENCRYPTION_KEY=change-me-strong-random
# Public HTTPS base URL (must match the OAuth Redirect URL in Slack config)
PUBLIC_BASE_URL=https://your-app.onrender.com
# Tamper-evident audit chain secret
AUDIT_HMAC_SECRET=change-me-strong-random
#
# ── Single-workspace (legacy) mode ──────────────────────────────────────────
# If you only run in your own workspace, set just these two instead:
#   Bot token:      OAuth & Permissions → Bot User OAuth Token (starts xoxb-)
# SLACK_BOT_TOKEN=xoxb-your-rotated-bot-token
#
PORT=3000
NODE_ENV=production
MAX_CONCURRENT_API_CALLS=10

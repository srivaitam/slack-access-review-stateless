# Copy to .env and fill in real values. Do NOT commit .env.
# Get these from https://api.slack.com/apps → your app:
#   Bot token:      OAuth & Permissions → Bot User OAuth Token (starts xoxb-)
#   Signing secret: Basic Information → App Credentials → Signing Secret
SLACK_BOT_TOKEN=xoxb-your-rotated-bot-token
SLACK_SIGNING_SECRET=your-rotated-signing-secret
PORT=3000
NODE_ENV=production
MAX_CONCURRENT_API_CALLS=10
